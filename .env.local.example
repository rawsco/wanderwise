# --- NextAuth ---
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Cognito (server-side OAuth) ---
# Pull from `sst dev` output or AWS Console (User Pool → App Integration → App client).
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=
COGNITO_REGION=eu-west-2

# --- Cognito (client-side, for sign-out redirect via Hosted UI) ---
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# --- DynamoDB (local Docker via docker-compose) ---
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_NAME=wanderwise-local
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- S3 / MinIO (local Docker) ---
S3_ENDPOINT=http://localhost:9002
S3_REGION=eu-west-2
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=wanderwise
NEXT_PUBLIC_S3_PUBLIC_URL=http://localhost:9002/wanderwise

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- AI provider for trip suggestions (lmstudio | bedrock) ---
AI_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
