#!/usr/bin/env bash
# bin/start-ticket — spin up an isolated workspace for a Jira ticket.
#
# Usage: bin/start-ticket <TICKET-KEY>
#
# Creates a git worktree in ../wanderwise-<TICKET>, allocates dynamic host
# ports, writes a per-worktree compose override and .env.local, generates
# a BRIEF.md, and prints instructions for starting the autonomous Claude
# session.
set -euo pipefail

# --- Args ---
[ $# -eq 1 ] || { echo "Usage: $0 <TICKET-KEY>" >&2; exit 2; }
TICKET="$1"

# --- Paths ---
BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$BIN_DIR/.." && pwd)"
cd "$ROOT_DIR"

# --- Pre-flight ---
for cmd in gh docker jq claude git nc; do
  command -v "$cmd" >/dev/null 2>&1 || {
    echo "missing required command: $cmd" >&2; exit 1; }
done
docker info >/dev/null 2>&1 || {
  echo "Docker daemon is not running" >&2; exit 1; }

ATLASSIAN_ENV="$HOME/.config/claude/atlassian.env"
[ -f "$ATLASSIAN_ENV" ] || {
  echo "missing $ATLASSIAN_ENV — see plan task 1" >&2; exit 1; }
set -a; . "$ATLASSIAN_ENV"; set +a

# The atlassian-jira MCP server expects ATLASSIAN_* names. Validate after
# sourcing — a malformed env file (missing names, typos) otherwise produces
# silent 401s on every Jira call rather than a clear setup error.
for var in ATLASSIAN_SITE_NAME ATLASSIAN_USER_EMAIL ATLASSIAN_API_TOKEN; do
  if [ -z "${!var:-}" ]; then
    echo "missing $var in $ATLASSIAN_ENV" >&2
    echo "expected lines: ATLASSIAN_SITE_NAME=<subdomain>, ATLASSIAN_USER_EMAIL=<email>, ATLASSIAN_API_TOKEN=<token>" >&2
    exit 1
  fi
done

# --- Source libs ---
. "$BIN_DIR/lib/ports.sh"

# --- Fetch ticket ---
echo "Fetching $TICKET from Jira..."
TICKET_JSON=$("$BIN_DIR/lib/jira.sh" fetch "$TICKET")

SUMMARY=$(echo "$TICKET_JSON" | jq -r .summary)
DESCRIPTION=$(echo "$TICKET_JSON" | jq -r .description)
STATUS=$(echo "$TICKET_JSON" | jq -r .status)
URL=$(echo "$TICKET_JSON" | jq -r .url)

if [ "$STATUS" = "Done" ] || [ "$STATUS" = "Closed" ]; then
  echo "Ticket $TICKET is $STATUS — refusing to start work." >&2
  "$BIN_DIR/lib/jira.sh" label-add "$TICKET" claude-blocked >/dev/null 2>&1 || \
    echo "warning: failed to label $TICKET claude-blocked" >&2
  exit 1
fi
if [ -z "$DESCRIPTION" ] || [ "$DESCRIPTION" = "null" ]; then
  echo "Ticket $TICKET has no description — refusing." >&2
  "$BIN_DIR/lib/jira.sh" label-add "$TICKET" claude-blocked >/dev/null 2>&1 || \
    echo "warning: failed to label $TICKET claude-blocked" >&2
  exit 1
fi

# --- Allocate ports ---
PORTS_OUTPUT=$(allocate_workspace_ports)
DDB_PORT=$(echo "$PORTS_OUTPUT" | grep ^DDB_PORT= | cut -d= -f2)
MINIO_API_PORT=$(echo "$PORTS_OUTPUT" | grep ^MINIO_API_PORT= | cut -d= -f2)
MINIO_CONSOLE_PORT=$(echo "$PORTS_OUTPUT" | grep ^MINIO_CONSOLE_PORT= | cut -d= -f2)
NEXT_PORT=$(echo "$PORTS_OUTPUT" | grep ^NEXT_PORT= | cut -d= -f2)

# --- Detect LAN host (so the Jira "ready to test" comment is reachable
#     from another machine on the local network). ---
LAN_HOST=""
if command -v ipconfig >/dev/null 2>&1; then
  for iface in en0 en1 en2 en3; do
    candidate=$(ipconfig getifaddr "$iface" 2>/dev/null || true)
    if [ -n "$candidate" ]; then LAN_HOST="$candidate"; break; fi
  done
fi
if [ -z "$LAN_HOST" ] && command -v ip >/dev/null 2>&1; then
  LAN_HOST=$(ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' | head -1)
fi
if [ -z "$LAN_HOST" ]; then
  LAN_HOST=$(hostname -I 2>/dev/null | awk '{print $1}' || true)
fi
[ -n "$LAN_HOST" ] || LAN_HOST="localhost"

# --- Worktree ---
TICKET_LOWER=$(echo "$TICKET" | tr '[:upper:]' '[:lower:]')
WORKTREE_DIR="../wanderwise-$TICKET"
PROJECT_NAME="wanderwise-$TICKET_LOWER"

cleanup_partial() {
  if [ -d "$WORKTREE_DIR" ]; then
    git worktree remove --force "$WORKTREE_DIR" 2>/dev/null || true
  fi
  git branch -D "$TICKET_LOWER" 2>/dev/null || true
}
trap cleanup_partial ERR

git worktree add "$WORKTREE_DIR" -b "$TICKET_LOWER"

# --- Compose override ---
mkdir -p "$WORKTREE_DIR/.docker"
cat > "$WORKTREE_DIR/.docker/compose.override.yml" <<YAML
services:
  dynamodb-local:
    ports:
      - "${DDB_PORT}:8000"
  minio:
    ports:
      - "${MINIO_API_PORT}:9000"
      - "${MINIO_CONSOLE_PORT}:9001"
YAML

cat > "$WORKTREE_DIR/.env.compose" <<ENV
DDB_PORT=$DDB_PORT
MINIO_API_PORT=$MINIO_API_PORT
MINIO_CONSOLE_PORT=$MINIO_CONSOLE_PORT
NEXT_PORT=$NEXT_PORT
LAN_HOST=$LAN_HOST
ENV

# --- .env.local seeded with per-worktree ports ---
if [ -f .env.local.example ]; then
  cp .env.local.example "$WORKTREE_DIR/.env.local"
  # Substitute defaults to dynamic ports.
  sed -i.bak \
    -e "s|http://localhost:8000|http://localhost:$DDB_PORT|g" \
    -e "s|http://localhost:9002|http://localhost:$MINIO_API_PORT|g" \
    -e "s|http://localhost:3000|http://localhost:$NEXT_PORT|g" \
    "$WORKTREE_DIR/.env.local"
  rm -f "$WORKTREE_DIR/.env.local.bak"
fi

# --- BRIEF.md ---
# Build the file with `printf '%s'` per field so $SUMMARY/$DESCRIPTION/$URL
# (which come from arbitrary Jira ticket content) cannot be reinterpreted
# as shell — `$(...)` or backticks in a ticket description otherwise execute
# at script runtime via the heredoc.
ABS_WORKTREE=$(cd "$WORKTREE_DIR" && pwd)
{
  printf '# %s — %s\n\n' "$TICKET" "$SUMMARY"
  printf '**Mode:** autonomous; refuse-back to Jira if ambiguous.\n\n'
  printf '**URL:** %s\n\n' "$URL"
  printf '**Worktree:** %s\n' "$ABS_WORKTREE"
  printf '**Branch:** %s\n' "$TICKET_LOWER"
  printf '**Compose project:** %s\n' "$PROJECT_NAME"
  printf '**LAN host:** %s\n\n' "$LAN_HOST"
  printf '**Ports allocated:**\n'
  printf -- '- Next.js dev: %s (test URL: http://%s:%s)\n' "$NEXT_PORT" "$LAN_HOST" "$NEXT_PORT"
  printf -- '- DynamoDB: %s\n' "$DDB_PORT"
  printf -- '- MinIO API: %s\n' "$MINIO_API_PORT"
  printf -- '- MinIO Console: %s (test URL: http://%s:%s)\n\n' "$MINIO_CONSOLE_PORT" "$LAN_HOST" "$MINIO_CONSOLE_PORT"
  printf '## Ticket description\n\n'
  printf '%s\n\n' "$DESCRIPTION"
  printf '## To run the local stack\n\n'
  printf '```bash\n'
  printf 'docker compose --env-file .env.compose -p %s \\\n' "$PROJECT_NAME"
  printf '  -f docker-compose.yml -f .docker/compose.override.yml up -d\n'
  printf 'npm run dev -- -p %s\n' "$NEXT_PORT"
  printf '```\n'
} > "$WORKTREE_DIR/BRIEF.md"

# --- Print summary ---
trap - ERR
cat <<SUMMARY

Workspace ready for $TICKET ($SUMMARY)

  Worktree:        $ABS_WORKTREE
  Branch:          $TICKET_LOWER
  Compose project: $PROJECT_NAME
  LAN host:        $LAN_HOST

  Next.js dev:     http://$LAN_HOST:$NEXT_PORT
  DynamoDB:        http://$LAN_HOST:$DDB_PORT
  MinIO API:       http://$LAN_HOST:$MINIO_API_PORT
  MinIO Console:   http://$LAN_HOST:$MINIO_CONSOLE_PORT

Next (autonomous, no permission prompts):
  cd $WORKTREE_DIR
  claude --dangerously-skip-permissions /ticket-work

SUMMARY
